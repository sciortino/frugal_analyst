# Financial Modeling Prep (free tier: 250 calls/day)
FMP_API_KEY=your_fmp_api_key_here

# FRED (Federal Reserve Economic Data)
FRED_API_KEY=your_fred_api_key_here

# BLS (Bureau of Labor Statistics, v2 registration key)
BLS_API_KEY=your_bls_api_key_here

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# SEC EDGAR requires a User-Agent with contact email
SEC_EDGAR_EMAIL=your_email@example.com

# Google Analytics 4 Measurement ID (PUBLIC_ prefix required for Astro client-side access)
PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

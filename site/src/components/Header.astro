---
const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home', match: (p: string) => p === '/' },
  { href: '/blog/', label: 'Archive', match: (p: string) => p.startsWith('/blog') || p.startsWith('/tags') },
  { href: '/tools/', label: 'Tools', match: (p: string) => p.startsWith('/tools') },
  { href: '/about/', label: 'About', match: (p: string) => p.startsWith('/about') },
];
---
<header class="site-header">
  <div class="header-inner">
    <div class="site-title"><a href="/">The Frugal Analyst</a></div>
    <div class="site-subtitle">Data-driven analysis of corporate finance and labor economics</div>
    <nav class="site-nav">
      {navLinks.map((link) => (
        <a href={link.href} class={link.match(pathname) ? 'active' : ''}>{link.label}</a>
      ))}
    </nav>
  </div>
</header>

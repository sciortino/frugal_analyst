---
interface Props {
  id: string;
  title: string;
  date: Date;
  ticker: string;
  company: string;
  description: string;
  tags: string[];
}

const { id, title, date, ticker, company, description, tags } = Astro.props;
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---
<article class="post-card">
  <h2 class="post-card-title">
    <a href={`/blog/${id}/`}>{title}</a>
  </h2>
  <div class="post-card-meta">
    <time datetime={date.toISOString()}>{formattedDate}</time>
    <span><span class="ticker-badge">{ticker}</span> {company}</span>
  </div>
  <p class="post-card-description">{description}</p>
  <div class="tags">
    {tags.map((tag) => (
      <a href={`/tags/${tag}/`} class="tag">{tag}</a>
    ))}
  </div>
</article>
